<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Ministify - Digital Operations Hub</title>
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    
    <!-- OPTIMIZATION: Preload FontAwesome Webfont to prevent icon pop-in delay -->
    <link rel="preload" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/webfonts/fa-solid-900.woff2" as="font" type="font/woff2" crossorigin="anonymous">
    
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700;900&family=Playfair+Display:ital,wght@0,700;1,400&family=Inter:wght@400;500;600;700;800;900&family=Roboto+Mono:wght@400;500&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <style>
        /* --- 1. SETTINGS & VARIABLES --- */
        :root {
            --primary-hero: #008080;
            --bg-start: #f8f9fa; 
            --bg-end: #e2e8f0;  
            --text-main: #1f2937; 
            --google-blue: #4285F4;
            --google-green: #34A853;
        }

        /* --- 2. GLOBAL RESET & NEURAL BACKGROUND --- */
        * { margin: 0; padding: 0; box-sizing: border-box; }
        
        body {
            font-family: 'Inter', sans-serif;
            background: linear-gradient(135deg, var(--bg-start), var(--bg-end));
            color: var(--text-main);
            min-height: 100vh;
            padding: 40px 20px; 
            overflow-x: hidden; 
        }

        /* --- NEURAL CONSTELLATION STYLES --- */
        #particle-container {
            position: fixed;
            top: 0;
            left: 0;
            width: 100vw;
            height: 100vh;
            pointer-events: none;
            z-index: 0;
            overflow: hidden;
        }

        #constellation-svg {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
        }

        .atom {
            position: absolute;
            width: 5px; 
            height: 5px;
            background-color: var(--google-blue); 
            border-radius: 50%;
            box-shadow: 0 0 10px rgba(66, 133, 244, 0.8);
            /* Center offset to align perfectly with SVG lines */
            margin-top: -2.5px;
            margin-left: -2.5px;
            will-change: transform;
        }

        .connection {
            stroke: var(--google-blue);
            stroke-width: 1px;
            opacity: 0; /* Hidden by default */
            will-change: opacity, x1, y1, x2, y2;
        }

        /* --- 3. CENTERED LAYOUT WRAPPER --- */
        .ministify-wrapper {
            position: relative;
            z-index: 10;
            width: 100%;
            max-width: 1100px;
            margin: 0 auto;
            display: flex;
            flex-direction: column;
            gap: 20px;
        }

        /* HEADER / HERO SECTION */
        .dashboard-header {
            padding: 20px 0 30px;
            display: flex;
            flex-direction: column;
            align-items: center;
            text-align: center;
        }
        
        .hero-headline {
            font-size: clamp(2rem, 4vw, 3.5rem);
            font-weight: 900;
            color: #0f172a;
            line-height: 1.15;
            margin-bottom: 15px;
            letter-spacing: -1px;
        }

        .gradient-text {
            background: linear-gradient(90deg, #3b82f6, #10b981);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            display: inline-block;
        }

        .hero-subtext {
            font-size: 1rem;
            color: #475569;
            max-width: 750px;
            margin: 0 auto 25px;
            line-height: 1.6;
            font-weight: 400;
        }

        .header-actions { display: flex; gap: 12px; justify-content: center; }
        .action-btn {
            text-decoration: none; padding: 12px 28px; border-radius: 8px;
            font-weight: 600; transition: all 0.2s; font-size: 0.95rem;
            display: flex; align-items: center; gap: 8px; cursor: pointer;
        }
        .btn-primary { background: var(--primary-hero); color: #ffffff; border: 1px solid var(--primary-hero); box-shadow: 0 4px 6px rgba(0, 128, 128, 0.2); }
        .btn-secondary { background: #ffffff; color: var(--text-main); border: 1px solid #cbd5e1; }
        .action-btn:hover { transform: translateY(-2px); box-shadow: 0 8px 15px rgba(0,0,0,0.08); }
        .btn-secondary:hover { border-color: var(--primary-hero); color: var(--primary-hero); }

        /* BODY SECTION */
        .dashboard-body {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 30px;
        }

        .widget-panel {
            background: #ffffff;
            border: 1px solid #e2e8f0;
            border-radius: 16px;
            padding: 55px 20px 30px 20px; 
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: flex-start;
            position: relative;
            box-shadow: 0 10px 25px -5px rgba(0,0,0,0.05);
            min-height: 350px;
            overflow: hidden; 
        }
        
        .widget-title {
            position: absolute; 
            top: 20px; 
            left: 50%;
            transform: translateX(-50%);
            font-size: 0.8rem; 
            font-weight: 800; 
            text-transform: uppercase;
            color: #94a3b8; 
            letter-spacing: 4px;
            user-select: none;
            white-space: nowrap;
            z-index: 10;
        }

        /* --- LOADER STYLES --- */
        .widget-loader {
            position: absolute;
            inset: 0;
            background: #ffffff;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            z-index: 200;
            transition: opacity 0.5s ease, visibility 0.5s ease;
        }
        .widget-loader.hidden {
            opacity: 0;
            visibility: hidden;
        }
        .spinner {
            width: 36px;
            height: 36px;
            border: 3px solid #f1f5f9;
            border-top-color: #4285F4;
            border-radius: 50%;
            animation: loader-spin 0.8s linear infinite;
        }
        .loader-text {
            margin-top: 12px;
            font-size: 0.75rem;
            font-weight: 700;
            color: #94a3b8;
            letter-spacing: 2px;
            text-transform: uppercase;
            animation: pulse-text 1.5s ease-in-out infinite;
        }
        @keyframes loader-spin { 100% { transform: rotate(360deg); } }
        @keyframes pulse-text { 0%, 100% { opacity: 0.5; } 50% { opacity: 1; } }

        /* --- 4. MINIATURIZED ORBIT WIDGET --- */
        #orbit-wrapper {
            position: relative; width: 220px; height: 220px; margin-top: 15px;
            border-radius: 50%; border: none; 
            display: flex; align-items: center; justify-content: center;
            transform-style: preserve-3d; transition: transform 0.4s ease;
        }
        #orbit-wrapper:hover .orbit-ring, #orbit-wrapper:hover .app-icon { animation-play-state: paused; }

        .orbit-ring { position: absolute; width: 0; height: 0; animation: spin 60s linear infinite; z-index: 5; }
        .orbit-ring.paused { animation-play-state: paused !important; }
        @keyframes spin { 100% { transform: rotate(360deg); } }

        .spoke { position: absolute; top: 0; left: 0; width: 40px; height: 40px; margin: -20px 0 0 -20px; }
        .spoke:nth-child(1) { transform: rotate(0deg)   translate(75px) rotate(0deg); }
        .spoke:nth-child(2) { transform: rotate(60deg)  translate(75px) rotate(-60deg); }
        .spoke:nth-child(3) { transform: rotate(120deg) translate(75px) rotate(-120deg); }
        .spoke:nth-child(4) { transform: rotate(180deg) translate(75px) rotate(-180deg); }
        .spoke:nth-child(5) { transform: rotate(240deg) translate(75px) rotate(-240deg); }
        .spoke:nth-child(6) { transform: rotate(300deg) translate(75px) rotate(-300deg); }

        .app-icon {
            width: 100%; height: 100%; border-radius: 50%; background: white;
            display: flex; align-items: center; justify-content: center;
            box-shadow: 0 4px 10px rgba(0,0,0,0.1); cursor: pointer; border: 2px solid white;
            transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            animation: counter-spin 60s linear infinite;
        }
        .orbit-ring.paused .app-icon { animation-play-state: paused !important; }
        @keyframes counter-spin { 100% { transform: rotate(-360deg); } }
        .app-icon:hover { transform: scale(1.2); z-index: 100; box-shadow: 0 6px 15px rgba(66, 133, 244, 0.2); }
        .app-icon i { font-size: 15px; color: white; }

        /* GOOGLE THEME COLORS */
        .c1 { background: linear-gradient(135deg, #4285F4, #1967D2); }
        .c2 { background: linear-gradient(135deg, #EA4335, #C5221F); }
        .c3 { background: linear-gradient(135deg, #F9AB00, #E37400); }
        .c4 { background: linear-gradient(135deg, #34A853, #188038); }
        .c5 { background: linear-gradient(135deg, #AF5CF7, #8430CE); }
        .c6 { background: linear-gradient(135deg, #12B5CB, #00899B); }

        .hub {
            width: 70px; height: 70px; background: white; border-radius: 50%; position: absolute; z-index: 1;
            display: flex; flex-direction: column; align-items: center; justify-content: center;
            box-shadow: 0 0 15px rgba(66, 133, 244, 0.1); border: 3px solid #f1f5f9;
        }
        .hub h1 { margin:0; font-size: 10px; font-weight:800; color:#0f172a; }
        .hub span { font-size: 6px; text-transform:uppercase; letter-spacing:1px; color:#4285F4; margin-top:2px; font-weight: 600;}

        /* --- SHARED ACCORDION STYLES --- */
        .widget-accordion {
            max-height: 0; overflow: hidden; opacity: 0;
            transition: max-height 0.4s ease, opacity 0.3s ease, margin 0.3s ease;
            width: 100%; border-radius: 12px;
            position: relative; z-index: 10;
        }
        .widget-accordion.open { max-height: 500px; opacity: 1; margin-top: 20px; }
        .widget-accordion .accordion-inner { 
            padding: 25px; text-align: left; background: #f8fafc; 
            border: 1px solid #e2e8f0; border-radius: 12px; 
            position: relative; box-shadow: inset 0 2px 4px rgba(0,0,0,0.02);
        }

        .acc-close {
            position: absolute; top: 15px; right: 15px; font-size: 1.4rem; cursor: pointer;
            color: #64748b; border: none; background: #f1f5f9; transition: 0.2s; line-height: 1;
            width: 32px; height: 32px; border-radius: 50%; display: flex; align-items: center; justify-content: center; z-index: 10;
        }
        .acc-close:hover { color: #0f172a; transform: rotate(90deg); background: #e2e8f0; }

        .modal-color-bar { height: 4px; width: 50px; border-radius: 2px; margin-bottom: 12px; }
        .modal-title { font-size: 1.3rem; font-weight: 800; margin: 0 0 12px; color: #0f172a; padding-right: 35px; line-height: 1.2;}
        .modal-body { color: #475569; font-size: 0.85rem; line-height: 1.5; }

        .rich-list { list-style: none; padding: 0; margin: 0; }
        .rich-list li { position: relative; padding-left: 20px; margin-bottom: 8px; font-size: 0.85rem; color: #475569; line-height: 1.5; }
        .rich-list li::before { content: '→'; position: absolute; left: 0; top: 0; color: #4285F4; font-weight: bold; }

        /* --- 5. GLOBAL MAIN MODALS --- */
        .main-modal-wrapper {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(15, 23, 42, 0.6); backdrop-filter: blur(5px); -webkit-backdrop-filter: blur(5px);
            z-index: 9999; display: flex; align-items: center; justify-content: center;
            opacity: 0; pointer-events: none; transition: opacity 0.3s ease; padding: 20px;
        }
        .main-modal-wrapper.active { opacity: 1; pointer-events: auto; }
        .main-modal-box {
            background: #ffffff; width: 100%; max-width: 550px; border-radius: 20px;
            padding: 40px; position: relative; transform: translateY(30px); transition: transform 0.4s ease, max-width 0.4s ease;
            box-shadow: 0 25px 50px -12px rgba(0,0,0,0.25); text-align: left;
            max-height: 90vh; overflow-y: auto;
        }
        .main-modal-box.wide { max-width: 850px; }
        
        .main-modal-wrapper.active .main-modal-box { transform: translateY(0); }
        .main-modal-close-btn {
            position: absolute; top: 20px; right: 20px; background: #f1f5f9; border: none;
            width: 36px; height: 36px; border-radius: 50%; cursor: pointer; color: #64748b;
            display: flex; align-items: center; justify-content: center; transition: 0.2s; z-index: 50;
        }
        .main-modal-close-btn:hover { background: #e2e8f0; color: #0f172a; transform: rotate(90deg); }

        /* --- MODAL CALCULATOR STYLES --- */
        .calc-nav { display: flex; flex-wrap: wrap; border-bottom: 1px solid #e2e8f0; margin-bottom: 20px; margin-top: 10px; }
        .calc-tab { flex: 1; padding: 12px; cursor: pointer; font-weight: 600; font-size: 0.95rem; color: #64748b; text-align: center; border-bottom: 3px solid transparent; transition: all 0.2s; }
        .calc-tab:hover { color: #0f172a; background: #f8fafc; }
        .calc-tab.active { color: var(--google-blue); border-bottom-color: var(--google-blue); background: transparent; }
        
        .calc-panel { display: none; animation: fadeIn 0.4s ease forwards; }
        .calc-panel.active { display: block; }
        @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }

        .calculator-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(min(100%, 350px), 1fr)); gap: 40px; align-items: start; }
        
        .slider-group { margin-bottom: 1.8rem; }
        .slider-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.5rem; font-weight: 600; font-size: 0.95rem; color: #334155;}
        .slider-val { color: var(--google-blue); font-size: 1.1rem; font-family: 'Roboto Mono', monospace; font-weight: 700; white-space: nowrap;}
        
        .modal-calc input[type=range] { width: 100%; accent-color: var(--google-blue); cursor: pointer; height: 6px; border-radius: 3px; background: #e2e8f0; outline: none; margin-top: 5px; }
        .modal-calc select { width: 100%; padding: 0.6rem 1rem; font-size: 0.95rem; font-family: inherit; border: 1px solid #cbd5e1; border-radius: 8px; background-color: #f8fafc; color: #0f172a; cursor: pointer; outline: none; margin-top: 5px;}
        .modal-calc select:focus { border-color: var(--google-blue); box-shadow: 0 0 0 2px rgba(66, 133, 244, 0.2); }
        .slider-helper { font-size: 0.8rem; color: #64748b; margin-top: 0.5rem; line-height: 1.4; }

        .results-panel h3 { margin-bottom: 1.2rem; font-size: 1.1rem; padding-bottom: 0.8rem; border-bottom: 1px solid #e2e8f0; color: #0f172a;}
        .breakdown-row { display: flex; justify-content: space-between; margin-bottom: 0.8rem; font-size: 0.9rem; color: #475569; font-family: 'Roboto Mono', monospace; gap: 1rem;}
        .breakdown-row span:last-child { color: #0f172a; font-weight: 600; text-align: right;}
        
        .total-row { display: flex; justify-content: space-between; align-items: center; margin-top: 1.5rem; padding-top: 1.5rem; border-top: 2px dashed #cbd5e1; gap: 1rem; flex-wrap: wrap;}
        .total-row .label { font-size: 1.1rem; font-weight: 800; color: #0f172a;}
        .savings-amount { font-size: 2.2rem; font-weight: 800; color: var(--google-green); font-family: 'Roboto Mono', monospace; letter-spacing: -1px;}
        .quote-amount { color: var(--google-blue); } 

        .widget-cta { width: 100%; margin-top: 2rem; padding: 1rem; background: var(--google-blue); color: #ffffff; border: none; border-radius: 8px; font-size: 0.95rem; font-weight: 700; cursor: pointer; transition: 0.2s; text-transform: uppercase; letter-spacing: 1px; box-shadow: 0 4px 6px rgba(66, 133, 244, 0.2); }
        .widget-cta:hover { background: #1967D2; transform: translateY(-2px); box-shadow: 0 6px 12px rgba(66, 133, 244, 0.3);}

        /* --- 6. RESPONSIVE --- */
        @media (max-width: 900px) {
            .dashboard-body { grid-template-columns: 1fr; }
            .header-actions { width: 100%; flex-wrap: wrap; }
            .action-btn { flex: 1; justify-content: center; min-width: 140px;}
            .widget-panel { padding: 50px 20px 30px 20px; } 
        }
        @media (max-width: 600px) {
            .main-modal-box { padding: 30px 20px; }
            .total-row { flex-direction: column; align-items: flex-start; }
            .calc-tab { font-size: 0.85rem; padding: 10px; }
        }
    </style>
</head>
<body>

    <!-- NEURAL CONSTELLATION BACKGROUND CONTAINER -->
    <div id="particle-container"></div>

    <!-- WRAPPER -->
    <div class="ministify-wrapper">
        
        <!-- HEADER -->
        <header class="dashboard-header">
            <h1 class="hero-headline">AI-centric <br><span class="gradient-text">Tech Stack</span></h1>
            <p class="hero-subtext">Ministify liberates organizations from expensive licenses and locked-down hardware. We help to set-up a unified ecosystem powered by Google's web-based Infrastructure, Linux Systems, and Agentic AI models.</p>
            
            <div class="header-actions">
                <button id="btn-quote" class="action-btn btn-primary"><i class="fas fa-calculator"></i> Quote</button>
                <button id="btn-contact" class="action-btn btn-secondary"><i class="fas fa-paper-plane"></i> Contact</button>
            </div>
        </header>

        <!-- BODY / WIDGET PANELS -->
        <main class="dashboard-body">
            
            <!-- PANEL 1: DECK CAROUSEL -->
            <div class="widget-panel">
                <div class="widget-loader">
                    <div class="spinner"></div>
                    <div class="loader-text">Loading</div>
                </div>

                <div class="widget-title">ENTERPRISE</div>
                <ministify-ecosystem-deck></ministify-ecosystem-deck>
            </div>

            <!-- PANEL 2: ORBIT NAVIGATOR -->
            <div class="widget-panel">
                <div class="widget-loader">
                    <div class="spinner"></div>
                    <div class="loader-text">Loading</div>
                </div>

                <div class="widget-title">EXPERTISE</div>
                
                <div id="orbit-wrapper">
                    <div class="hub">
                        <h1>MINISTIFY</h1>
                        <span>CORE</span>
                    </div>
                    <div class="orbit-ring" id="ring">
                        <div class="spoke"><div class="app-icon c1" onclick="Orbit.open('apps')"><i class="fa-solid fa-laptop-code"></i></div></div>
                        <div class="spoke"><div class="app-icon c2" onclick="Orbit.open('ai')"><i class="fa-solid fa-robot"></i></div></div>
                        <div class="spoke"><div class="app-icon c3" onclick="Orbit.open('courses')"><i class="fa-solid fa-graduation-cap"></i></div></div>
                        <div class="spoke"><div class="app-icon c4" onclick="Orbit.open('webdev')"><i class="fa-solid fa-server"></i></div></div>
                        <div class="spoke"><div class="app-icon c5" onclick="Orbit.open('support')"><i class="fa-solid fa-shield-halved"></i></div></div>
                        <div class="spoke"><div class="app-icon c6" onclick="Orbit.open('evangelism')"><i class="fa-solid fa-chart-line"></i></div></div>
                    </div>
                </div>

                <!-- Orbit Accordion -->
                <div id="orbit-accordion" class="widget-accordion">
                    <div class="accordion-inner" id="orbit-acc-content"></div>
                </div>
            </div>

        </main>
    </div>

    <!-- GLOBAL MAIN MODALS -->
    <div id="main-modal" class="main-modal-wrapper">
        <div class="main-modal-box">
            <button id="main-modal-close" class="main-modal-close-btn">
                <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" fill="none" stroke-width="2.5"><path d="M18 6L6 18M6 6l12 12"/></svg>
            </button>
            <div id="main-modal-content"></div>
        </div>
    </div>

<script>
    // --- 0. NEURAL CONSTELLATION BACKGROUND LOGIC ---
    // No Canvas used! Only DOM and SVG elements.
    const particleContainer = document.getElementById('particle-container');
    let animationFrameId;
    let nodes = [];
    let lines = [];
    let mouseLines = [];
    let mouseX = -1000;
    let mouseY = -1000;

    // Tuning parameters
    const connectionDist = 160; 
    const mouseDist = 220;      

    function initConstellation() {
        if (animationFrameId) cancelAnimationFrame(animationFrameId);
        
        // Reset and inject the SVG layer
        particleContainer.innerHTML = '<svg id="constellation-svg"></svg>';
        const svg = document.getElementById('constellation-svg');
        
        nodes = [];
        lines = [];
        mouseLines = [];

        // Dynamically scale atom count based on screen size so performance is smooth
        const numNodes = Math.min(Math.floor((window.innerWidth * window.innerHeight) / 20000), 50);

        // 1. Initialize DOM Nodes (Atoms)
        for (let i = 0; i < numNodes; i++) {
            const el = document.createElement('div');
            el.className = 'atom';
            particleContainer.appendChild(el);
            
            nodes.push({
                el: el,
                x: Math.random() * window.innerWidth,
                y: Math.random() * window.innerHeight,
                vx: (Math.random() - 0.5) * 1.5,
                vy: (Math.random() - 0.5) * 1.5
            });
        }

        // 2. Initialize Node-to-Node Connection Pool (SVG Lines)
        for (let i = 0; i < numNodes; i++) {
            for (let j = i + 1; j < numNodes; j++) {
                const line = document.createElementNS('http://www.w3.org/2000/svg', 'line');
                line.setAttribute('class', 'connection');
                svg.appendChild(line);
                lines.push({ line, n1: nodes[i], n2: nodes[j] });
            }
        }

        // 3. Initialize Mouse-to-Node Connection Pool (SVG Lines)
        for (let i = 0; i < numNodes; i++) {
            const line = document.createElementNS('http://www.w3.org/2000/svg', 'line');
            line.setAttribute('class', 'connection');
            svg.appendChild(line);
            mouseLines.push({ line, n: nodes[i] });
        }

        animateConstellation();
    }

    function animateConstellation() {
        // Physics and Movement
        nodes.forEach(n => {
            let dxMouse = mouseX - n.x;
            let dyMouse = mouseY - n.y;
            let distMouse = Math.sqrt(dxMouse * dxMouse + dyMouse * dyMouse);
            
            // "Neural pull": Atoms reach slightly toward the mouse if nearby
            if (distMouse < mouseDist && distMouse > 0) {
                const force = (mouseDist - distMouse) / mouseDist;
                n.vx += (dxMouse / distMouse) * force * 0.08;
                n.vy += (dyMouse / distMouse) * force * 0.08;
            }

            // Move
            n.x += n.vx;
            n.y += n.vy;

            // Softly bounce off boundaries
            if (n.x <= 0) { n.x = 0; n.vx *= -1; }
            if (n.x >= window.innerWidth) { n.x = window.innerWidth; n.vx *= -1; }
            if (n.y <= 0) { n.y = 0; n.vy *= -1; }
            if (n.y >= window.innerHeight) { n.y = window.innerHeight; n.vy *= -1; }

            // Add organic friction and enforce a minimum/maximum floating speed
            n.vx *= 0.99; 
            n.vy *= 0.99;
            const speed = Math.sqrt(n.vx * n.vx + n.vy * n.vy);
            
            if (speed < 0.3) {
                n.vx += (Math.random() - 0.5) * 0.1;
                n.vy += (Math.random() - 0.5) * 0.1;
            } else if (speed > 2.5) {
                n.vx *= 0.9;
                n.vy *= 0.9;
            }

            // Update purely via translate3d for GPU acceleration
            n.el.style.transform = `translate3d(${n.x}px, ${n.y}px, 0)`;
        });

        // Calculate Node-to-Node connections
        lines.forEach(l => {
            let dx = l.n1.x - l.n2.x;
            let dy = l.n1.y - l.n2.y;
            let dist = Math.sqrt(dx * dx + dy * dy);
            
            if (dist < connectionDist) {
                l.line.setAttribute('x1', l.n1.x);
                l.line.setAttribute('y1', l.n1.y);
                l.line.setAttribute('x2', l.n2.x);
                l.line.setAttribute('y2', l.n2.y);
                // Opacity fades as they drift apart
                l.line.style.opacity = (1 - (dist / connectionDist)) * 0.6; 
            } else {
                l.line.style.opacity = 0;
            }
        });

        // Calculate Mouse-to-Node connections
        mouseLines.forEach(l => {
            let dx = l.n.x - mouseX;
            let dy = l.n.y - mouseY;
            let dist = Math.sqrt(dx * dx + dy * dy);
            
            if (dist < mouseDist) {
                l.line.setAttribute('x1', l.n.x);
                l.line.setAttribute('y1', l.n.y);
                l.line.setAttribute('x2', mouseX);
                l.line.setAttribute('y2', mouseY);
                // Mouse lines are slightly stronger/brighter
                l.line.style.opacity = 1 - (dist / mouseDist);
            } else {
                l.line.style.opacity = 0;
            }
        });

