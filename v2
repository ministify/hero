            { primary: '#12B5CB', gradient: 'linear-gradient(135deg, #12B5CB, #00899B)' } 
        ];
        this.angle = 360 / this.cardData.length;
        this.radius = 150; 
    }

    connectedCallback() {
        this.deck = this.shadowRoot.querySelector('#deck');
        this.accWrap = this.shadowRoot.querySelector('#deck-accordion');
        this.componentWrap = this.shadowRoot.querySelector('#ecosystem-deck-component');
        
        this.shadowRoot.querySelector('#next-card').onclick = () => this.navigate('next');
        this.shadowRoot.querySelector('#prev-card').onclick = () => this.navigate('prev');
        this.shadowRoot.querySelector('#action-btn').onclick = () => this.toggleAccordion();
        
        this.shadowRoot.querySelector('#modal-close').onclick = () => {
            this.accWrap.classList.remove('open');
            this.startAutoplay();
        };
        
        let touchStartX = 0;
        this.deck.addEventListener('touchstart', (e) => { 
            touchStartX = e.touches[0].clientX; 
            this.stopAutoplay();
        }, {passive: true});
        
        this.deck.addEventListener('touchend', (e) => {
            let touchEndX = e.changedTouches[0].clientX;
            if (Math.abs(touchEndX - touchStartX) > 20) {
                if (touchEndX < touchStartX - 30) this.navigate('next'); 
                if (touchEndX > touchStartX + 30) this.navigate('prev'); 
            }
            if(!this.accWrap.classList.contains('open')) {
                this.startAutoplay();
            }
        });

        this.componentWrap.addEventListener('mouseenter', () => this.stopAutoplay());
        this.componentWrap.addEventListener('mouseleave', () => {
            if(!this.accWrap.classList.contains('open')) {
                this.startAutoplay();
            }
        });
        
        this.createCards();
        this.updateScene();
        this.startAutoplay();
    }

    disconnectedCallback() {
        this.stopAutoplay();
    }

    startAutoplay() {
        if (!this.autoplayInterval) {
            this.autoplayInterval = setInterval(() => this.navigate('next'), 5000);
        }
    }

    stopAutoplay() {
        if (this.autoplayInterval) {
            clearInterval(this.autoplayInterval);
            this.autoplayInterval = null;
        }
    }

    resetAutoplay() {
        this.stopAutoplay();
        if(!this.accWrap.classList.contains('open')) {
            this.startAutoplay();
        }
    }

    createCards() {
        this.deck.innerHTML = '';
        this.cardData.forEach((card, i) => {
            const cardEl = document.createElement('div');
            cardEl.className = 'deck-card';
            cardEl.style.setProperty('--rotY', `${this.angle * i}deg`);
            cardEl.style.setProperty('--transZ', `${this.radius}px`);
            cardEl.innerHTML = `
                <div class="card-content" style="background: ${this.cardStyles[i].gradient}">
                    <div class="card-icon"><svg viewBox="0 0 24 24">${card.icon}</svg></div>
                    <div class="deck-card-title">${card.title}</div>
                    <div class="deck-card-desc">${card.shortDesc}</div>
                </div>`;
            this.deck.appendChild(cardEl);
        });
    }

    updateScene() {
        this.deck.style.transform = `translateZ(-${this.radius}px) rotateY(${this.currentStep * -this.angle}deg)`;
        const count = this.cardData.length;
        this.activeIndex = ((this.currentStep % count) + count) % count;
        
        this.shadowRoot.querySelector('#action-btn').style.setProperty('--btn-bg', this.cardStyles[this.activeIndex].primary);
        
        const cards = this.shadowRoot.querySelectorAll('.deck-card');
        cards.forEach((card, i) => {
            let diff = Math.abs(i - this.activeIndex);
            if (diff > count / 2) diff = count - diff;
            card.style.zIndex = 100 - diff;
            if (diff > 1) { 
                card.style.pointerEvents = 'none'; card.style.setProperty('-webkit-box-reflect', 'none');
            } else { 
                card.style.pointerEvents = 'auto'; card.style.setProperty('-webkit-box-reflect', 'below 1px linear-gradient(transparent, transparent, rgba(0,0,0,0.1))');
            }
        });

        if(this.accWrap.classList.contains('open')) {
            const data = this.cardData[this.activeIndex];
            this.shadowRoot.querySelector('#modal-title').textContent = data.modalTitle;
            this.shadowRoot.querySelector('#modal-body').innerHTML = data.modalBody; 
            this.shadowRoot.querySelector('#modal-color-bar').style.background = this.cardStyles[this.activeIndex].gradient;
        }
    }

    navigate(dir) { 
        dir === 'next' ? this.currentStep++ : this.currentStep--; 
        this.updateScene(); 
        this.resetAutoplay();
    }

    toggleAccordion() {
        if(this.accWrap.classList.contains('open')) {
            this.accWrap.classList.remove('open');
            this.startAutoplay();
        } else {
            this.stopAutoplay();
            const data = this.cardData[this.activeIndex];
            this.shadowRoot.querySelector('#modal-title').textContent = data.modalTitle;
            this.shadowRoot.querySelector('#modal-body').innerHTML = data.modalBody; 
            this.shadowRoot.querySelector('#modal-color-bar').style.background = this.cardStyles[this.activeIndex].gradient;
            this.accWrap.classList.add('open');
        }
    }
}
